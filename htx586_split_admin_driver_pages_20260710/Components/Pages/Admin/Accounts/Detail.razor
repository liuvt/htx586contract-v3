@page "/admin/accounts/{UserId}"
@attribute [Authorize(Roles = "Owner")]
@inject IAdminAccountService AdminAccountService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Chi tiết Admin</PageTitle>
<PageHeader Title="Chi tiết Admin" Subtitle="Xem thông tin tài khoản Admin và CompanyProfile được gán." />

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_model is null)
{
    <MudAlert Severity="Severity.Error">Không tìm thấy tài khoản Admin.</MudAlert>
}
else
{
    <MudPaper Class="pa-4" Elevation="1">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Tên đăng nhập</MudText>
                <MudText Typo="Typo.h6">@_model.UserName</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Quyền</MudText>
                <MudText>@Display(_model.Roles)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">CompanyProfile</MudText>
                <MudText>@Display(_model.CompanyName)</MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.caption">Họ và tên</MudText>
                <MudText>@Display(_model.FullName)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Mã nhân viên</MudText>
                <MudText>@Display(_model.EmployeeCode)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Số điện thoại</MudText>
                <MudText>@Display(_model.PhoneNumber)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Email</MudText>
                <MudText>@Display(_model.Email)</MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle1">Trạng thái</MudText>

                <MudStack Row="true" Spacing="2">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@(_model.IsActive ? Color.Success : Color.Error)">
                        @(_model.IsActive ? "Tài khoản hoạt động" : "Tài khoản đã khóa")
                    </MudChip>

                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@(_model.MustChangePassword ? Color.Warning : Color.Success)">
                        @(_model.MustChangePassword ? "Bắt buộc đổi mật khẩu" : "Không bắt buộc đổi mật khẩu")
                    </MudChip>
                </MudStack>
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Class="mt-4">
            <MudButton Variant="Variant.Outlined"
                       OnClick="@(() => Navigation.NavigateTo("/admin/accounts"))">
                Quay lại
            </MudButton>

            <MudSpacer />

            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Edit"
                       OnClick="@(() => Navigation.NavigateTo($"/admin/accounts/{UserId}/edit"))">
                Cập nhật
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public string UserId { get; set; } = string.Empty;

    private AdminAccountDetail? _model;
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        try
        {
            _model = await AdminAccountService.GetDetailAsync(UserId);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string Display(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "—" : value;
}
