@page "/admin/accounts"
@attribute [Authorize(Roles = "Owner")]
@inject IAdminAccountService AdminAccountService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Admin</PageTitle>
<PageHeader Title="Admin" Subtitle="Quản lý thông tin và quyền hạn của các tài khoản Admin trong hệ thống." />

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudTextField T="string"
                          @bind-Value="_keyword"
                          Placeholder="Tìm Admin, họ tên, mã nhân viên, công ty..."
                          Immediate="true"
                          Clearable="true"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" />
        </MudItem>

        <MudItem xs="12" md="4" Class="d-flex align-center justify-end">
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => Navigation.NavigateTo("/admin/accounts/create"))">
                Tạo Admin
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable T="AdminAccountListItem"
          Items="FilteredItems"
          Loading="_loading"
          Hover="true"
          Striped="true"
          Breakpoint="Breakpoint.Sm">
    <HeaderContent>
        <MudTh>Tài khoản</MudTh>
        <MudTh>Quyền</MudTh>
        <MudTh>Họ tên</MudTh>
        <MudTh>CompanyProfile</MudTh>
        <MudTh>Điện thoại</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Trạng thái</MudTh>
        <MudTh></MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd DataLabel="Tài khoản">@context.UserName</MudTd>
        <MudTd DataLabel="Quyền">@(context.Roles ?? "—")</MudTd>
        <MudTd DataLabel="Họ tên">
            @context.FullName<br />
            <small>@(context.EmployeeCode ?? "—")</small>
        </MudTd>
        <MudTd DataLabel="CompanyProfile">@(context.CompanyName ?? "—")</MudTd>
        <MudTd DataLabel="Điện thoại">@(context.PhoneNumber ?? "—")</MudTd>
        <MudTd DataLabel="Email">@(context.Email ?? "—")</MudTd>
        <MudTd DataLabel="Trạng thái">
            <MudChip T="string"
                     Size="Size.Small"
                     Color="@(context.IsActive ? Color.Success : Color.Error)">
                @(context.IsActive ? "Hoạt động" : "Đã khóa")
            </MudChip>
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                           Color="Color.Info"
                           OnClick="@(() => Navigation.NavigateTo($"/admin/accounts/{context.Id}"))" />

            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Color="Color.Primary"
                           OnClick="@(() => Navigation.NavigateTo($"/admin/accounts/{context.Id}/edit"))" />
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private bool _loading;
    private string? _keyword;
    private IReadOnlyList<AdminAccountListItem> _items = [];

    private IEnumerable<AdminAccountListItem> FilteredItems =>
        string.IsNullOrWhiteSpace(_keyword)
            ? _items
            : _items.Where(x =>
                Contains(x.UserName) ||
                Contains(x.FullName) ||
                Contains(x.EmployeeCode) ||
                Contains(x.PhoneNumber) ||
                Contains(x.Email) ||
                Contains(x.CompanyName) ||
                Contains(x.Roles));

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        try
        {
            _items = await AdminAccountService.GetAccountsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private bool Contains(string? value) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(_keyword!.Trim(), StringComparison.OrdinalIgnoreCase);
}
