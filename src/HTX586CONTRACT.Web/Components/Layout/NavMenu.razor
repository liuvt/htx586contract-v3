            <MudNavLink Href="/admin/customers" Icon="@Icons.Material.Filled.Groups">Khách hàng</MudNavLink>
            <MudNavLink Href="/admin/contracts" Icon="@Icons.Material.Filled.Description">Hợp đồng</MudNavLink>
