@page "/account/driver-register"
@layout AuthLayout
@attribute [AllowAnonymous]
@inject IDriverAccountService DriverAccountService
@inject ICompanyProfileService CompanyProfileService
@inject ISnackbar Snackbar

<PageTitle>Đăng ký tài khoản tài xế</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="driver-register-page pa-0">
    <MudPaper Elevation="0" Class="pa-4 register-card">
        <MudText Typo="Typo.h5" Align="Align.Center">Đăng ký tài khoản tài xế</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mb-4">
            Hồ sơ sẽ bị khóa cho đến khi Owner/Admin xét duyệt.
        </MudText>

        <div class="step-strip mb-4">
            @for (var step = 1; step <= 4; step++)
            {
                <div class="step-item @(step == _step ? "active" : step < _step ? "done" : null)">
                    <span>@step/4</span>
                </div>
            }
        </div>

        @if (_submitted)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Filled">
                Đã gửi yêu cầu đăng ký. Vui lòng chờ quản trị viên xét duyệt.
            </MudAlert>
            <MudButton Href="/account/login" FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">
                Về trang đăng nhập
            </MudButton>
        }
        else
        {
            <MudForm @ref="_form">
                @if (_step == 1)
                {
                    <MudText Typo="Typo.h6" Class="mb-3">Thông tin tài khoản</MudText>
                    <MudTextField @bind-Value="_model.UserName" Label="Tên đăng nhập" Required="true" Immediate="true"
                                  Variant="Variant.Outlined" Class="mb-3" Autocomplete="username" />
                    <MudTextField @bind-Value="_model.PhoneNumber" Label="Số điện thoại" Required="true" Immediate="true"
                                  HelperText="@VietnamPhoneNumber.ValidationMessage" Variant="Variant.Outlined" Class="mb-3" />
                    <MudTextField @bind-Value="_model.Password" Label="Mật khẩu" Required="true" Immediate="true"
                                  InputType="@(_showPassword ? InputType.Text : InputType.Password)" Variant="Variant.Outlined"
                                  Adornment="Adornment.End" AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(()=> _showPassword = !_showPassword)" Autocomplete="new-password" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Mật khẩu tối thiểu 6 ký tự và có ít nhất 1 chữ số.</MudText>
                }
                else if (_step == 2)
                {
                    <MudText Typo="Typo.h6" Class="mb-3">Thông tin cá nhân</MudText>
                    <MudSelect T="Guid" @bind-Value="_model.CompanyProfileId" Label="Công ty / Chi nhánh" Required="true" Variant="Variant.Outlined" Class="mb-3">
                        @foreach (var company in _companies)
                        {
                            <MudSelectItem Value="@company.Id">@(string.IsNullOrWhiteSpace(company.BranchName) ? company.CompanyName : $"{company.CompanyName} - {company.BranchName}")</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTextField @bind-Value="_model.FullName" Label="Họ và tên" Required="true" Variant="Variant.Outlined" Class="mb-3" />
                    <MudDatePicker @bind-Date="_model.DateOfBirth" Label="Ngày sinh" Required="true" Variant="Variant.Outlined" Class="mb-3" MaxDate="@DateTime.Today" />
                    <MudTextField @bind-Value="_model.AreaCode" Label="Khu vực" Required="true" Variant="Variant.Outlined" Class="mb-3" />
                    <MudTextField @bind-Value="_model.Address" Label="Địa chỉ chi tiết" Required="true" Lines="2" Variant="Variant.Outlined" Class="mb-3" />
                    <MudTextField @bind-Value="_model.CitizenId" Label="Số CCCD" Required="true" Variant="Variant.Outlined" Class="mb-3" />
                    <MudDatePicker @bind-Date="_model.CitizenIdIssuedDate" Label="Ngày cấp CCCD" Required="true" Variant="Variant.Outlined" Class="mb-3" MaxDate="@DateTime.Today" />
                    <MudTextField @bind-Value="_model.CitizenIdIssuedPlace" Label="Nơi cấp CCCD" Required="true" Variant="Variant.Outlined" />
                }
                else if (_step == 3)
                {
                    <MudText Typo="Typo.h6" Class="mb-3">Giấy phép lái xe</MudText>
                    <MudTextField @bind-Value="_model.DriverLicenseNumber" Label="Số GPLX" Required="true" Variant="Variant.Outlined" Class="mb-3" />
                    <MudTextField @bind-Value="_model.DriverLicenseClass" Label="Hạng GPLX" Required="true" Variant="Variant.Outlined" Class="mb-3" />
                    <MudDatePicker @bind-Date="_model.DriverLicenseIssuedDate" Label="Ngày cấp GPLX" Required="true" Variant="Variant.Outlined" Class="mb-3" MaxDate="@DateTime.Today" />
                    <MudDatePicker @bind-Date="_model.DriverLicenseExpiryDate" Label="Ngày hết hạn" Required="true" Variant="Variant.Outlined" Class="mb-3" />
                    @if (IsLicenseExpired)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true">GPLX đã hết hạn. Bạn không thể gửi hồ sơ cho đến khi cập nhật ngày hết hạn hợp lệ.</MudAlert>
                    }
                    else if (IsLicenseNearExpiry)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">GPLX sắp hết hạn trong vòng 30 ngày.</MudAlert>
                    }
                }
                else
                {
                    <MudText Typo="Typo.h6" Class="mb-1">Ký xác nhận</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                        Ký và lưu tạm để xem lại. Chữ ký chỉ được lưu thật khi bạn bấm “Xác nhận và gửi yêu cầu đăng ký”.
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(_model.SignatureDataUrl))
                    {
                        <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                            Chữ ký đã được lưu tạm để xem lại. Bạn có thể xóa và ký lại nếu chưa đúng.
                        </MudAlert>
                    }
                    <SignaturePad @key="_signaturePadKey"
                                  SignerName="@_model.FullName"
                                  ExistingSignatureUrl="@_model.SignatureDataUrl"
                                  ConfirmationButtonText="Lưu chữ ký tạm"
                                  SavedStatusText="Đã lưu tạm"
                                  AllowRemoveSavedSignature="true"
                                  OnSavedSignatureRemoved="RemovePendingSignatureAsync"
                                  OnSignatureSaved="CaptureSignatureAsync" />
                }

                <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-4">
                    <MudButton Variant="Variant.Text" Disabled="@(_step == 1 || _saving)" OnClick="PreviousStep">Quay lại</MudButton>
                    @if (_step < 4)
                    {
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="NextStepAsync">Tiếp tục</MudButton>
                    }
                    else
                    {
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="@(_saving || string.IsNullOrWhiteSpace(_model.SignatureDataUrl))" OnClick="SubmitAsync">
                            @(_saving ? "Đang gửi..." : "Xác nhận và gửi yêu cầu đăng ký")
                        </MudButton>
                    }
                </MudStack>
            </MudForm>
            <MudButton Href="/account/login" FullWidth="true" Variant="Variant.Text" Class="mt-2">Đã có tài khoản</MudButton>
        }
    </MudPaper>
</MudContainer>

<style>
.driver-register-page { padding: 12px !important; }
.register-card { border-radius: 18px; }
.step-strip { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; }
.step-item { height:34px; border-radius:999px; display:flex; align-items:center; justify-content:center; background:var(--mud-palette-background-grey); color:var(--mud-palette-text-secondary); font-weight:700; font-size:.8rem; }
.step-item.active { background:var(--mud-palette-primary); color:var(--mud-palette-primary-text); }
.step-item.done { background:var(--mud-palette-success); color:var(--mud-palette-success-text); }
@@media (max-width: 600px) { .driver-register-page { padding:0 !important; } .register-card { border-radius:0; min-height:100vh; } }
</style>

@code {
    private MudForm? _form;
    private int _step = 1;
    private bool _saving;
    private bool _submitted;
    private bool _showPassword;
    private readonly string _signaturePadKey = $"driver-register-signature-{Guid.NewGuid():N}";
    private SelfRegisterDriverRequest _model = new();
    private IReadOnlyList<CompanyProfileOptionDto> _companies = [];

    private bool IsLicenseExpired => _model.DriverLicenseExpiryDate.HasValue && _model.DriverLicenseExpiryDate.Value.Date < DateTime.Today;
    private bool IsLicenseNearExpiry => _model.DriverLicenseExpiryDate.HasValue && !IsLicenseExpired && _model.DriverLicenseExpiryDate.Value.Date <= DateTime.Today.AddDays(30);

    protected override async Task OnInitializedAsync()
    {
        _companies = await CompanyProfileService.GetActiveOptionsAsync();
        _model.CompanyProfileId = _companies.FirstOrDefault()?.Id ?? Guid.Empty;
    }

    private async Task NextStepAsync()
    {
        var error = ValidateStep(_step);
        if (error is not null) { Snackbar.Add(error, Severity.Warning); return; }
        _step++;
        await InvokeAsync(StateHasChanged);
    }

    private void PreviousStep() => _step = Math.Max(1, _step - 1);

    private string? ValidateStep(int step) => step switch
    {
        1 when string.IsNullOrWhiteSpace(_model.UserName) || string.IsNullOrWhiteSpace(_model.PhoneNumber) || string.IsNullOrWhiteSpace(_model.Password) => "Vui lòng nhập tên đăng nhập, số điện thoại và mật khẩu.",
        1 when !VietnamPhoneNumber.TryNormalize(_model.PhoneNumber, out _) => VietnamPhoneNumber.ValidationMessage,
        1 when _model.Password.Length < 6 || !_model.Password.Any(char.IsDigit) => "Mật khẩu phải có tối thiểu 6 ký tự và ít nhất 1 chữ số.",
        2 when _model.CompanyProfileId == Guid.Empty || string.IsNullOrWhiteSpace(_model.FullName) || _model.DateOfBirth is null ||
               string.IsNullOrWhiteSpace(_model.AreaCode) || string.IsNullOrWhiteSpace(_model.Address) || string.IsNullOrWhiteSpace(_model.CitizenId) ||
               _model.CitizenIdIssuedDate is null || string.IsNullOrWhiteSpace(_model.CitizenIdIssuedPlace) => "Vui lòng nhập đầy đủ thông tin cá nhân và CCCD.",
        3 when string.IsNullOrWhiteSpace(_model.DriverLicenseNumber) || string.IsNullOrWhiteSpace(_model.DriverLicenseClass) ||
               _model.DriverLicenseIssuedDate is null || _model.DriverLicenseExpiryDate is null => "Vui lòng nhập đầy đủ thông tin GPLX.",
        3 when IsLicenseExpired => "GPLX đã hết hạn, vui lòng kiểm tra lại.",
        _ => null
    };

    private Task CaptureSignatureAsync(string signature)
    {
        _model.SignatureDataUrl = signature;
        Snackbar.Add("Đã lưu chữ ký tạm. Hãy xem lại trước khi xác nhận gửi hồ sơ.", Severity.Success);
        return Task.CompletedTask;
    }

    private Task RemovePendingSignatureAsync()
    {
        _model.SignatureDataUrl = null;
        Snackbar.Add("Đã xóa chữ ký tạm. Vui lòng ký lại.", Severity.Info);
        return Task.CompletedTask;
    }

    private async Task SubmitAsync()
    {
        if (ValidateStep(3) is { } error) { Snackbar.Add(error, Severity.Warning); _step = 3; return; }
        if (string.IsNullOrWhiteSpace(_model.SignatureDataUrl)) { Snackbar.Add("Vui lòng ký tên và bấm Xác nhận chữ ký.", Severity.Warning); return; }
        try
        {
            _saving = true;
            await DriverAccountService.SubmitRegistrationAsync(_model);
            _submitted = true;
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _saving = false; }
    }
}
