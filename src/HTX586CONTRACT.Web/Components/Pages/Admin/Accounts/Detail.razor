@page "/admin/accounts/{UserId}"
@attribute [Authorize(Roles = "Owner")]
@inject IAdminAccountService AdminAccountService
@inject ICompanyProfileService CompanyProfileService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Cập nhật tài khoản</PageTitle>
<PageHeader Title="Cập nhật tài khoản" Subtitle="Owner chỉnh thông tin tài khoản và gán lại CompanyProfile cho Admin." />

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_model is null)
{
    <MudAlert Severity="Severity.Error">Không tìm thấy tài khoản.</MudAlert>
}
else
{
    <MudPaper Class="pa-4" Elevation="1">
        <MudGrid>
            <MudItem xs="12" md="4"><MudTextField Value="@_model.UserName" Label="Tên đăng nhập" Disabled="true" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField Value="@_model.Roles" Label="Quyền" Disabled="true" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="Guid?" @bind-Value="_model.CompanyProfileId" Label="CompanyProfile" Variant="Variant.Outlined" Clearable="true">
                    @foreach (var company in _companies)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)company.Id)">@company.CompanyName (@company.TaxCode)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_model.FullName" Label="Họ và tên" Required="true" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_model.EmployeeCode" Label="Mã nhân viên" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_model.PhoneNumber" Label="Số điện thoại" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="6"><MudSwitch T="bool" @bind-Value="_model.IsActive" Color="Color.Success" Label="Tài khoản hoạt động" /></MudItem>
            <MudItem xs="12" md="6"><MudSwitch T="bool" @bind-Value="_model.MustChangePassword" Color="Color.Warning" Label="Bắt buộc đổi mật khẩu" /></MudItem>
        </MudGrid>
        <MudStack Row="true" Class="mt-4">
            <MudButton Variant="Variant.Outlined" OnClick="@(() => Navigation.NavigateTo("/admin/accounts"))">Quay lại</MudButton>
            <MudSpacer />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_saving" OnClick="SaveAsync">Lưu thay đổi</MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public string UserId { get; set; } = string.Empty;
    private AdminAccountDetail? _model;
    private IReadOnlyList<CompanyProfileOptionDto> _companies = [];
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        try
        {
            _companies = await CompanyProfileService.GetActiveOptionsAsync();
            _model = await AdminAccountService.GetDetailAsync(UserId);
        }
        finally { _loading = false; }
    }

    private async Task SaveAsync()
    {
        if (_model is null) return;
        _saving = true;
        try
        {
            var result = await AdminAccountService.UpdateAccountAsync(new UpdateAdminAccountRequest
            {
                UserId = _model.Id,
                CompanyProfileId = _model.CompanyProfileId,
                FullName = _model.FullName,
                EmployeeCode = _model.EmployeeCode,
                PhoneNumber = _model.PhoneNumber,
                Email = _model.Email,
                IsActive = _model.IsActive,
                MustChangePassword = _model.MustChangePassword
            });
            Snackbar.Add(result.Message ?? string.Join("; ", result.Errors), result.Succeeded ? Severity.Success : Severity.Error);
        }
        finally { _saving = false; }
    }
}
