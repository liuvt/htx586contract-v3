@page "/admin/accounts/{UserId}/edit"
@attribute [Authorize(Roles = "Owner")]
@inject IAdminAccountService AdminAccountService
@inject ICompanyProfileService CompanyProfileService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Cập nhật Admin</PageTitle>
<PageHeader Title="Cập nhật Admin" Subtitle="Owner chỉnh thông tin Admin, gán CompanyProfile và reset mật khẩu Admin. Owner được tách khỏi luồng này." />

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_model is null)
{
    <MudAlert Severity="Severity.Error">Không tìm thấy tài khoản Admin.</MudAlert>
}
else
{
    <MudPaper Class="pa-4" Elevation="1">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Value="@_model.UserName"
                              Label="Tên đăng nhập"
                              Disabled="true"
                              Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Value="@_model.Roles"
                              Label="Quyền"
                              Disabled="true"
                              Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudSelect T="Guid?"
                           @bind-Value="_model.CompanyProfileId"
                           Label="CompanyProfile"
                           Variant="Variant.Outlined"
                           Clearable="true">
                    @foreach (var company in _companies)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)company.Id)">
                            @company.CompanyName (@company.TaxCode)
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_model.FullName" Label="Họ và tên" Required="true" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.EmployeeCode" Label="Mã nhân viên" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.PhoneNumber" Label="Số điện thoại" Required="true" HelperText="@VietnamPhoneNumber.ValidationMessage" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSwitch T="bool"
                           @bind-Value="_model.IsActive"
                           Color="Color.Success"
                           Label="Tài khoản hoạt động" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSwitch T="bool"
                           @bind-Value="_model.MustChangePassword"
                           Color="Color.Warning"
                           Label="Bắt buộc đổi mật khẩu" />
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Class="mt-4">
            <MudButton Variant="Variant.Outlined"
                       OnClick="@(() => Navigation.NavigateTo($"/admin/accounts/{UserId}"))">
                Quay lại
            </MudButton>

            <MudSpacer />

            <MudButton Color="Color.Warning"
                       Variant="Variant.Outlined"
                       Disabled="@(_saving || _resettingPassword)"
                       OnClick="ResetPasswordAsync">
                Reset mật khẩu Admin
            </MudButton>

            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       Disabled="@(_saving || _resettingPassword)"
                       OnClick="SaveAsync">
                Lưu thay đổi
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public string UserId { get; set; } = string.Empty;

    private AdminAccountDetail? _model;
    private IReadOnlyList<CompanyProfileOptionDto> _companies = [];
    private bool _loading = true;
    private bool _saving;
    private bool _resettingPassword;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        try
        {
            _companies = await CompanyProfileService.GetActiveOptionsAsync();
            _model = await AdminAccountService.GetDetailAsync(UserId);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_model is null)
            return;

        _saving = true;

        try
        {
            var result = await AdminAccountService.UpdateAccountAsync(new UpdateAdminAccountRequest
            {
                UserId = _model.Id,
                CompanyProfileId = _model.CompanyProfileId,
                FullName = _model.FullName,
                EmployeeCode = _model.EmployeeCode,
                PhoneNumber = _model.PhoneNumber,
                Email = _model.Email,
                IsActive = _model.IsActive,
                MustChangePassword = _model.MustChangePassword
            });

            Snackbar.Add(
                result.Message ?? string.Join("; ", result.Errors),
                result.Succeeded ? Severity.Success : Severity.Error);

            if (result.Succeeded)
            {
                _model = await AdminAccountService.GetDetailAsync(UserId);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ResetPasswordAsync()
    {
        if (_model is null)
            return;

        _resettingPassword = true;

        try
        {
            var result = await AdminAccountService.ResetPasswordToDefaultAsync(_model.Id);

            Snackbar.Add(
                result.Message ?? string.Join("; ", result.Errors),
                result.Succeeded ? Severity.Success : Severity.Error);

            if (result.Succeeded)
            {
                _model.MustChangePassword = true;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _resettingPassword = false;
        }
    }
}
