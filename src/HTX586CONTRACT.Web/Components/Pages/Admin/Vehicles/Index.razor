@page "/admin/vehicles"
@attribute [Authorize(Roles = "Owner")]
@inject IDbContextFactory<ApplicationDbContext> Factory
@inject ICompanyProfileService CompanyProfileService
@inject ISnackbar Snackbar
@inject MasterSignatureService MasterSignatureService

<PageTitle>Xe và chủ sở hữu</PageTitle>
<PageHeader Title="Quản lý xe" Subtitle="Quản lý thông tin các phương tiện và chủ sở hữu xe trong hệ thống." />

<MudPaper Class="pa-4" Elevation="1">
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudSelect T="Guid?" @bind-Value="_model.CompanyProfileId" Label="CompanyProfile quản lý xe" Required="true" Variant="Variant.Outlined">
                @foreach (var company in _companies)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)company.Id)">@company.CompanyName (@company.TaxCode)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect T="string" @bind-Value="_model.AssignedDriverId" Label="Tài xế được giao xe" Variant="Variant.Outlined" Clearable="true">
                @foreach (var driver in DriverOptions)
                {
                    <MudSelectItem T="string" Value="@driver.Id">@driver.FullName - @(driver.PhoneNumber ?? driver.UserName)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="2"><MudTextField @bind-Value="_model.PlateNumber" Label="Biển số" Required="true" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="2"><MudTextField @bind-Value="_model.VehicleCode" Label="Mã xe" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="3"><MudTextField @bind-Value="_model.Brand" Label="Nhãn hiệu" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="3"><MudNumericField T="int?" @bind-Value="_model.SeatCount" Label="Số chỗ" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="4"><MudTextField @bind-Value="_model.OwnerName" Label="Chủ sở hữu xe" Required="true" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="4"><MudTextField @bind-Value="_model.OwnerCitizenId" Label="CCCD chủ xe" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="4"><MudTextField @bind-Value="_model.OwnerPhoneNumber" Label="Điện thoại chủ xe" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="4"><MudDatePicker @bind-Date="_model.OwnerCitizenIdIssuedDate" Label="Ngày cấp CCCD" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="8"><MudTextField @bind-Value="_model.OwnerCitizenIdIssuedPlace" Label="Nơi cấp CCCD" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12"><MudTextField @bind-Value="_model.OwnerAddress" Label="Địa chỉ chủ xe" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.subtitle1">Chữ ký cố định chủ xe</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Contract sẽ tự động lấy chữ ký này theo xe được chọn.</MudText>
            <SignaturePad ExistingSignatureUrl="@_model.OwnerSignatureFileUrl"
                          SignerName="@_model.OwnerName"
                          SignedAt="@_model.OwnerSignedAt"
                          OnSignatureSaved="CaptureOwnerSignature" />
            @if (!string.IsNullOrWhiteSpace(_ownerSignatureDataUrl))
            {
                <MudChip T="string" Class="mt-2" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.Check">Đã nhận chữ ký cố định</MudChip>
            }
        </MudItem>
        <MudItem xs="12">
            <MudStack Row="true"><MudButton Variant="Variant.Outlined" Disabled="@(!_editing)" OnClick="ResetForm">Hủy sửa</MudButton><MudSpacer /><MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_saving" OnClick="SaveAsync">@(_editing ? "Cập nhật xe" : "Thêm xe")</MudButton></MudStack>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable T="Vehicle" Items="_items" Loading="_loading" Hover="true" Striped="true" Class="mt-4" Breakpoint="Breakpoint.Sm">
    <HeaderContent><MudTh>Biển số</MudTh><MudTh>CompanyProfile</MudTh><MudTh>Tài xế được giao</MudTh><MudTh>Nhãn hiệu</MudTh><MudTh>Số chỗ</MudTh><MudTh>Chủ sở hữu</MudTh><MudTh>Chữ ký</MudTh><MudTh>Trạng thái</MudTh><MudTh></MudTh></HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Biển số"><b>@context.PlateNumber</b></MudTd>
        <MudTd DataLabel="CompanyProfile">@(context.CompanyProfile?.CompanyName ?? "Chưa gán")</MudTd>
        <MudTd DataLabel="Tài xế">@(context.AssignedDriver?.FullName ?? "Chưa gán")</MudTd>
        <MudTd DataLabel="Nhãn hiệu">@(context.Brand ?? "—")</MudTd>
        <MudTd DataLabel="Số chỗ">@(context.SeatCount?.ToString() ?? "—")</MudTd>
        <MudTd DataLabel="Chủ sở hữu">@context.OwnerName</MudTd>
        <MudTd DataLabel="Chữ ký"><MudChip T="string" Size="Size.Small" Color="@(string.IsNullOrWhiteSpace(context.OwnerSignatureFileUrl) ? Color.Warning : Color.Success)">@(string.IsNullOrWhiteSpace(context.OwnerSignatureFileUrl) ? "Thiếu" : "Đã lưu")</MudChip></MudTd>
        <MudTd DataLabel="Trạng thái"><MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">@(context.IsActive ? "Hoạt động" : "Ngừng")</MudChip></MudTd>
        <MudTd><MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="@(() => Edit(context))" /></MudTd>
    </RowTemplate>
    <NoRecordsContent><MudText Class="pa-4">Chưa có dữ liệu xe.</MudText></NoRecordsContent>
</MudTable>

@code {
    private List<Vehicle> _items = [];
    private Vehicle _model = NewVehicle();
    private IReadOnlyList<CompanyProfileOptionDto> _companies = [];
    private List<ApplicationUser> _drivers = [];
    private bool _loading;
    private bool _saving;
    private bool _editing;
    private string? _ownerSignatureDataUrl;

    private IEnumerable<ApplicationUser> DriverOptions => _model.CompanyProfileId.HasValue
        ? _drivers.Where(x => x.CompanyProfileId == _model.CompanyProfileId)
        : _drivers;

    protected override async Task OnInitializedAsync()
    {
        _companies = await CompanyProfileService.GetActiveOptionsAsync();
        _model.CompanyProfileId = _companies.FirstOrDefault()?.Id;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            await using var db = await Factory.CreateDbContextAsync();
            _drivers = await (from user in db.Users.AsNoTracking()
                              join userRole in db.UserRoles.AsNoTracking() on user.Id equals userRole.UserId
                              join role in db.Roles.AsNoTracking() on userRole.RoleId equals role.Id
                              where role.Name == "Driver" && user.IsActive && user.CompanyProfileId != null
                              orderby user.FullName
                              select user).ToListAsync();
            _items = await db.Vehicles.AsNoTracking()
                .Include(x => x.CompanyProfile)
                .Include(x => x.AssignedDriver)
                .OrderBy(x => x.PlateNumber)
                .ToListAsync();
        }
        finally { _loading = false; }
    }

    private void Edit(Vehicle item)
    {
        _editing = true;
        _model = new Vehicle
        {
            Id = item.Id,
            PlateNumber = item.PlateNumber,
            VehicleCode = item.VehicleCode,
            Brand = item.Brand,
            Model = item.Model,
            VehicleType = item.VehicleType,
            SeatCount = item.SeatCount,
            Color = item.Color,
            ChassisNumber = item.ChassisNumber,
            EngineNumber = item.EngineNumber,
            OwnerName = item.OwnerName,
            OwnerCitizenId = item.OwnerCitizenId,
            OwnerCitizenIdIssuedDate = item.OwnerCitizenIdIssuedDate,
            OwnerCitizenIdIssuedPlace = item.OwnerCitizenIdIssuedPlace,
            OwnerAddress = item.OwnerAddress,
            OwnerPhoneNumber = item.OwnerPhoneNumber,
            CompanyProfileId = item.CompanyProfileId,
            AssignedDriverId = item.AssignedDriverId,
            OwnerSignatureFileUrl = item.OwnerSignatureFileUrl,
            OwnerSignatureHash = item.OwnerSignatureHash,
            OwnerSignedAt = item.OwnerSignedAt,
            IsActive = item.IsActive
        };
        _ownerSignatureDataUrl = null;
    }

    private async Task SaveAsync()
    {
        if (_model.CompanyProfileId is null || _model.CompanyProfileId == Guid.Empty)
        {
            Snackbar.Add("Vui lòng gán CompanyProfile cho xe.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_model.PlateNumber) || string.IsNullOrWhiteSpace(_model.OwnerName))
        {
            Snackbar.Add("Vui lòng nhập biển số và chủ sở hữu xe.", Severity.Warning);
            return;
        }

        if (!string.IsNullOrWhiteSpace(_model.AssignedDriverId) &&
            !_drivers.Any(x => x.Id == _model.AssignedDriverId && x.CompanyProfileId == _model.CompanyProfileId))
        {
            Snackbar.Add("Tài xế được giao xe phải thuộc cùng CompanyProfile với xe.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_model.OwnerSignatureFileUrl) &&
            string.IsNullOrWhiteSpace(_ownerSignatureDataUrl))
        {
            Snackbar.Add("Vui lòng ký chữ ký cố định của chủ xe.", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            await using var db = await Factory.CreateDbContextAsync();
            var plate = _model.PlateNumber.Trim().ToUpperInvariant();
            if (await db.Vehicles.AnyAsync(x => x.PlateNumber == plate && x.Id != _model.Id))
            {
                Snackbar.Add("Biển số xe đã tồn tại.", Severity.Warning);
                return;
            }

            if (_editing)
            {
                var entity = await db.Vehicles.FirstAsync(x => x.Id == _model.Id);
                Map(entity, _model);
                entity.UpdatedAt = DateTime.UtcNow;
            }
            else
            {
                _model.Id = Guid.NewGuid();
                _model.PlateNumber = plate;
                db.Vehicles.Add(_model);
            }

            await db.SaveChangesAsync();

            if (!string.IsNullOrWhiteSpace(_ownerSignatureDataUrl))
                await MasterSignatureService.SaveVehicleOwnerSignatureAsync(_model.Id, _ownerSignatureDataUrl);

            Snackbar.Add(_editing ? "Đã cập nhật xe." : "Đã thêm xe và chữ ký cố định.", Severity.Success);
            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _saving = false; }
    }

    private Task CaptureOwnerSignature(string data)
    {
        _ownerSignatureDataUrl = data;
        Snackbar.Add("Đã nhận chữ ký cố định chủ xe.", Severity.Success);
        return Task.CompletedTask;
    }

    private void ResetForm()
    {
        _editing = false;
        _ownerSignatureDataUrl = null;
        _model = NewVehicle();
        _model.CompanyProfileId = _companies.FirstOrDefault()?.Id;
    }
    private static Vehicle NewVehicle() => new() { IsActive = true };

    private static void Map(Vehicle target, Vehicle source)
    {
        target.PlateNumber = source.PlateNumber.Trim().ToUpperInvariant();
        target.VehicleCode = source.VehicleCode;
        target.Brand = source.Brand;
        target.Model = source.Model;
        target.VehicleType = source.VehicleType;
        target.SeatCount = source.SeatCount;
        target.Color = source.Color;
        target.ChassisNumber = source.ChassisNumber;
        target.EngineNumber = source.EngineNumber;
        target.OwnerName = source.OwnerName.Trim();
        target.OwnerCitizenId = source.OwnerCitizenId;
        target.OwnerCitizenIdIssuedDate = source.OwnerCitizenIdIssuedDate;
        target.OwnerCitizenIdIssuedPlace = source.OwnerCitizenIdIssuedPlace;
        target.OwnerAddress = source.OwnerAddress;
        target.OwnerPhoneNumber = source.OwnerPhoneNumber;
        target.CompanyProfileId = source.CompanyProfileId;
        target.AssignedDriverId = source.AssignedDriverId;
        target.IsActive = source.IsActive;
    }
}
