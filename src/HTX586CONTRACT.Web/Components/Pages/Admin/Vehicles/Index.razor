@page "/admin/vehicles"
@attribute [Authorize(Roles = "Owner,Admin")]
@inject IDbContextFactory<ApplicationDbContext> Factory
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Xe và chủ sở hữu</PageTitle>
<PageHeader Title="Quản lý xe" Subtitle="Danh sách phương tiện và chủ sở hữu xe trong hệ thống." />

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudTextField T="string"
                          @bind-Value="_keyword"
                          Placeholder="Tìm theo biển số hoặc họ tên chủ sở hữu..."
                          Immediate="true"
                          Clearable="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="4" Class="d-flex align-center justify-end">
            @if (_isOwner)
            {
                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="@(() => Navigation.NavigateTo("/admin/vehicles/create"))">
                    Thêm xe
                </MudButton>
            }
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable T="Vehicle"
          Items="FilteredItems"
          Loading="_loading"
          Hover="true"
          Striped="true"
          RowsPerPage="20"
          Breakpoint="Breakpoint.Sm">

    <HeaderContent>
        <MudTh>Biển số</MudTh>
        <MudTh>CompanyProfile</MudTh>
        <MudTh>Tài xế được giao</MudTh>
        <MudTh>Nhãn hiệu</MudTh>
        <MudTh>Số chỗ</MudTh>
        <MudTh>Chủ sở hữu</MudTh>
        <MudTh>Chữ ký</MudTh>
        <MudTh>Trạng thái</MudTh>
        <MudTh></MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd DataLabel="Biển số">
            <b>@context.PlateNumber</b>
        </MudTd>

        <MudTd DataLabel="CompanyProfile">
            @(context.CompanyProfile?.CompanyName ?? "Chưa gán")
        </MudTd>

        <MudTd DataLabel="Tài xế">
            @(context.AssignedDriver?.FullName ?? "Chưa gán")
        </MudTd>

        <MudTd DataLabel="Nhãn hiệu">
            @(context.Brand ?? "—")
        </MudTd>

        <MudTd DataLabel="Số chỗ">
            @(context.SeatCount?.ToString() ?? "—")
        </MudTd>

        <MudTd DataLabel="Chủ sở hữu">
            @context.OwnerName
        </MudTd>

        <MudTd DataLabel="Chữ ký">
            <MudChip T="string"
                     Size="Size.Small"
                     Color="@(string.IsNullOrWhiteSpace(context.OwnerSignatureFileUrl) ? Color.Warning : Color.Success)">
                @(string.IsNullOrWhiteSpace(context.OwnerSignatureFileUrl) ? "Chưa có" : "Đã lưu")
            </MudChip>
        </MudTd>

        <MudTd DataLabel="Trạng thái">
            <MudChip T="string"
                     Size="Size.Small"
                     Color="@(context.IsActive ? Color.Success : Color.Default)">
                @(context.IsActive ? "Hoạt động" : "Ngừng")
            </MudChip>
        </MudTd>

        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                           Color="Color.Info"
                           OnClick="@(() => Navigation.NavigateTo($"/admin/vehicles/{context.Id}"))" />

            @if (_isOwner)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Color="Color.Primary"
                               OnClick="@(() => Navigation.NavigateTo($"/admin/vehicles/{context.Id}/edit"))" />
            }
        </MudTd>
    </RowTemplate>

    <NoRecordsContent>
        <MudText Class="pa-4">Không tìm thấy xe phù hợp.</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="_pageSizeOptions" />
    </PagerContent>
</MudTable>

@code {
    private static readonly int[] _pageSizeOptions = [10, 20, 50, 100];
    private List<Vehicle> _items = [];
    private string? _keyword;
    private bool _loading;
    private bool _isOwner;
    private Guid? _adminCompanyProfileId;

    private IEnumerable<Vehicle> FilteredItems =>
        string.IsNullOrWhiteSpace(_keyword)
            ? _items
            : _items.Where(x => Contains(x.PlateNumber) || Contains(x.OwnerName));

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isOwner = auth.User.IsInRole("Owner");

        if (!_isOwner)
        {
            var currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
            await using var db = await Factory.CreateDbContextAsync();
            _adminCompanyProfileId = await db.Users.AsNoTracking()
                .Where(x => x.Id == currentUserId)
                .Select(x => x.CompanyProfileId)
                .FirstOrDefaultAsync();
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        try
        {
            await using var db = await Factory.CreateDbContextAsync();

            var query = db.Vehicles.AsNoTracking()
                .Include(x => x.CompanyProfile)
                .Include(x => x.AssignedDriver)
                .AsQueryable();

            if (!_isOwner)
            {
                query = _adminCompanyProfileId.HasValue
                    ? query.Where(x => x.CompanyProfileId == _adminCompanyProfileId.Value)
                    : query.Where(x => false);
            }

            _items = await query
                .OrderBy(x => x.PlateNumber)
                .ToListAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private bool Contains(string? value) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(_keyword!.Trim(), StringComparison.OrdinalIgnoreCase);
}
