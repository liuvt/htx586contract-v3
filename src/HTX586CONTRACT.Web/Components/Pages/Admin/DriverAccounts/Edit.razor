@page "/admin/driver-accounts/{UserId}/edit"
@attribute [Authorize(Roles = "Owner,Admin")]
@using Microsoft.AspNetCore.Components.Forms
@inject IDriverAccountService DriverAccountService
@inject ICompanyProfileService CompanyProfileService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject MasterSignatureService MasterSignatureService
@inject IDbContextFactory<ApplicationDbContext> Factory
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Cập nhật tài xế</PageTitle>
<PageHeader Title="Cập nhật tài xế" Subtitle="Quản lý tài khoản, hồ sơ, CCCD, GPLX, Company và chữ ký tài xế." />

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_detail is null)
{
    <MudAlert Severity="Severity.Error">Không tìm thấy tài xế.</MudAlert>
}
else
{
    <MudForm @ref="_form" @bind-IsValid="_valid">
        <MudPaper Class="pa-4" Elevation="1">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Value="@_detail.UserName" Label="Tên đăng nhập" Disabled="true" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSelect T="Guid"
                               @bind-Value="_model.CompanyProfileId"
                               Label="Công ty/Văn phòng đại diện"
                               Required="true"
                               Variant="Variant.Outlined"
                               Disabled="@(!_canChooseCompany)">
                        @foreach (var company in _companies)
                        {
                            <MudSelectItem T="Guid" Value="@company.Id">
                                @company.CompanyName (@company.TaxCode)
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_model.FullName" Label="Họ và tên" Required="true" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_model.EmployeeCode" Label="Mã nhân viên" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_model.PhoneNumber" Label="Số điện thoại" Required="true" HelperText="@VietnamPhoneNumber.ValidationMessage" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_model.CitizenId" Label="Số CCCD" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_model.CitizenIdIssuedDate" Label="Ngày cấp CCCD" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_model.CitizenIdIssuedPlace" Label="Nơi cấp CCCD" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_model.DateOfBirth" Label="Ngày sinh" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_model.AreaCode" Label="Khu vực" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Address" Label="Địa chỉ" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_model.DriverLicenseNumber" Label="Số GPLX" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_model.DriverLicenseClass" Label="Hạng GPLX" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="2">
                    <MudDatePicker @bind-Date="_model.DriverLicenseIssuedDate" Label="Ngày cấp GPLX" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="2">
                    <MudDatePicker @bind-Date="_model.DriverLicenseExpiryDate" Label="Hết hạn GPLX" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSwitch T="bool"
                               @bind-Value="_model.IsActive"
                               Color="Color.Success"
                               Label="Tài khoản hoạt động" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudAlert Severity="@(_model.MustChangePassword ? Severity.Warning : Severity.Success)"
                              Variant="Variant.Outlined"
                              Dense="true">
                        @(_model.MustChangePassword
                            ? "Tài xế phải đổi mật khẩu ở lần đăng nhập kế tiếp."
                            : "Tài xế không bị yêu cầu đổi mật khẩu.")
                    </MudAlert>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle1">Chữ ký cố định tài xế</MudText>

                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Hợp đồng chỉ tự động lấy chữ ký khi chữ ký đang ở trạng thái sử dụng.
                    </MudText>

                    @if (_detail.DriverSignatureIsActive && !string.IsNullOrWhiteSpace(_detail.DriverSignatureFileUrl))
                    {
                        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="my-2">
                            Chữ ký đang sử dụng.
                        </MudAlert>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="my-2">
                            Chưa có chữ ký đang sử dụng hoặc chữ ký cũ đã bị hủy.
                        </MudAlert>
                    }

                    <SignaturePad ExistingSignatureUrl="@GetActiveDriverSignatureUrl()"
                                  SignerName="@_detail.FullName"
                                  SignedAt="@_detail.DriverSignedAt"
                                  OnSignatureSaved="SaveDriverSignatureAsync" />

                    <MudDivider Class="my-4" />

                </MudItem>
            </MudGrid>

            <MudStack Row="true" Class="mt-4">
                <MudButton Variant="Variant.Outlined"
                           OnClick="@(() => Navigation.NavigateTo($"/admin/driver-accounts/{UserId}"))">
                    Quay lại
                </MudButton>

                <MudSpacer />

                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           Disabled="_saving"
                           OnClick="SaveAsync">
                    Lưu thay đổi
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudForm>
}

@code {
    [Parameter] public string UserId { get; set; } = string.Empty;

    private MudForm? _form;
    private bool _valid;
    private bool _loading = true;
    private bool _saving;
    private bool _uploadingSignaturePng;

    private DriverAccountDetailDto? _detail;
    private UpdateDriverAccountRequest _model = new();
    private IReadOnlyList<CompanyProfileOptionDto> _companies = [];
    private bool _canChooseCompany;
    private Guid? _allowedCompanyId;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        try
        {
            var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();

            _canChooseCompany = auth.User.IsInRole("Owner");

            var allCompanies = await CompanyProfileService.GetActiveOptionsAsync();

            if (_canChooseCompany)
            {
                _companies = allCompanies;
            }
            else
            {
                var currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

                await using var db = await Factory.CreateDbContextAsync();

                _allowedCompanyId = await db.Users.AsNoTracking()
                    .Where(x => x.Id == currentUserId)
                    .Select(x => x.CompanyProfileId)
                    .FirstOrDefaultAsync();

                _companies = _allowedCompanyId.HasValue
                    ? allCompanies.Where(x => x.Id == _allowedCompanyId.Value).ToList()
                    : [];
            }

            await ReloadDetailAsync();

            if (_detail is not null && !_canChooseCompany && _detail.CompanyProfileId != _allowedCompanyId)
            {
                Snackbar.Add("Admin chỉ được quản lý tài xế thuộc CompanyProfile được gán.", Severity.Error);
                Navigation.NavigateTo("/admin/driver-accounts");
                _detail = null;
                return;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ReloadDetailAsync()
    {
        _detail = await DriverAccountService.GetDetailAsync(UserId);

        if (_detail is null)
            return;

        _model = new UpdateDriverAccountRequest
        {
            CompanyProfileId = _detail.CompanyProfileId ?? Guid.Empty,
            FullName = _detail.FullName,
            EmployeeCode = _detail.EmployeeCode,
            PhoneNumber = _detail.PhoneNumber,
            Email = _detail.Email,
            CitizenId = _detail.CitizenId,
            CitizenIdIssuedDate = _detail.CitizenIdIssuedDate,
            CitizenIdIssuedPlace = _detail.CitizenIdIssuedPlace,
            DateOfBirth = _detail.DateOfBirth,
            Address = _detail.Address,
            AreaCode = _detail.AreaCode,
            DriverLicenseNumber = _detail.DriverLicenseNumber,
            DriverLicenseClass = _detail.DriverLicenseClass,
            DriverLicenseIssuedDate = _detail.DriverLicenseIssuedDate,
            DriverLicenseExpiryDate = _detail.DriverLicenseExpiryDate,
            IsActive = _detail.IsActive,
            MustChangePassword = _detail.MustChangePassword
        };
    }

    private async Task SaveAsync()
    {
        await _form!.ValidateAsync();

        if (!_valid)
            return;

        _saving = true;

        try
        {
            await DriverAccountService.UpdateAsync(UserId, _model);

            Snackbar.Add("Đã cập nhật tài xế.", Severity.Success);

            await ReloadDetailAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveDriverSignatureAsync(string data)
    {
        try
        {
            await MasterSignatureService.SaveDriverSignatureAsync(UserId, data);

            Snackbar.Add("Đã lưu chữ ký cố định tài xế.", Severity.Success);

            await ReloadDetailAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private string? GetActiveDriverSignatureUrl()
    {
        if (_detail is null)
            return null;

        if (!_detail.DriverSignatureIsActive)
            return null;

        return _detail.DriverSignatureFileUrl;
    }
}
