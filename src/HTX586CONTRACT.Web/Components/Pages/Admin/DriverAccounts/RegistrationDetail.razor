@page "/admin/driver-registrations/{UserId}"
@attribute [Authorize(Roles = "Owner,Admin")]
@inject IDriverAccountService DriverAccountService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject DriverRegistrationNotificationState RegistrationNotificationState

<PageTitle>Chi tiết yêu cầu đăng ký</PageTitle>
<PageHeader Title="Chi tiết yêu cầu đăng ký" Subtitle="Kiểm tra hồ sơ trước khi duyệt hoặc từ chối." />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_item is null)
{
    <MudAlert Severity="Severity.Warning">Yêu cầu không tồn tại hoặc đã được xử lý.</MudAlert>
    <MudButton Href="/admin/driver-registrations" Variant="Variant.Text" Class="mt-3">Quay lại danh sách</MudButton>
}
else
{
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Outlined="true" Class="pa-4 h-100">
                <MudText Typo="Typo.h6" Class="mb-3">Tài khoản và đơn vị</MudText>
                <InfoListItem Label="Tên đăng nhập" Value="@_item.UserName" />
                <InfoListItem Label="Số điện thoại" Value="@_item.PhoneNumber" />
                <InfoListItem Label="Công ty / Chi nhánh" Value="@_item.CompanyName" />
                <InfoListItem Label="Ngày gửi" Value="@_item.RequestedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")" />
                <InfoListItem Label="Trạng thái xem" Value="@(_item.IsViewed ? "Đã xem" : "Chưa xem")" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Outlined="true" Class="pa-4 h-100">
                <MudText Typo="Typo.h6" Class="mb-3">Thông tin cá nhân</MudText>
                <InfoListItem Label="Họ và tên" Value="@_item.FullName" />
                <InfoListItem Label="Ngày sinh" Value="@FormatDate(_item.DateOfBirth)" />
                <InfoListItem Label="Khu vực" Value="@_item.AreaCode" />
                <InfoListItem Label="Địa chỉ" Value="@_item.Address" />
                <InfoListItem Label="Số CCCD" Value="@_item.CitizenId" />
                <InfoListItem Label="Ngày cấp CCCD" Value="@FormatDate(_item.CitizenIdIssuedDate)" />
                <InfoListItem Label="Nơi cấp CCCD" Value="@_item.CitizenIdIssuedPlace" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Outlined="true" Class="pa-4 h-100">
                <MudText Typo="Typo.h6" Class="mb-3">Giấy phép lái xe</MudText>
                <InfoListItem Label="Số GPLX" Value="@_item.DriverLicenseNumber" />
                <InfoListItem Label="Hạng GPLX" Value="@_item.DriverLicenseClass" />
                <InfoListItem Label="Ngày cấp" Value="@FormatDate(_item.DriverLicenseIssuedDate)" />
                <InfoListItem Label="Ngày hết hạn" Value="@FormatDate(_item.DriverLicenseExpiryDate)" />
                @if (_item.DriverLicenseExpiryDate.HasValue && _item.DriverLicenseExpiryDate.Value.Date < DateTime.Today)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">GPLX đã hết hạn.</MudAlert>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Outlined="true" Class="pa-4 h-100">
                <MudText Typo="Typo.h6" Class="mb-3">Chữ ký đăng ký</MudText>
                @if (!string.IsNullOrWhiteSpace(_item.DriverSignatureFileUrl))
                {
                    <img src="@_item.DriverSignatureFileUrl" alt="Chữ ký tài xế" class="registration-signature" />
                }
                else
                {
                    <MudAlert Severity="Severity.Warning">Không tìm thấy chữ ký.</MudAlert>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Outlined="true" Class="pa-4 mt-4">
        <MudTextField @bind-Value="_reviewNote" Label="Ghi chú xét duyệt" Lines="3" Variant="Variant.Outlined" />
        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3">
            <MudButton Variant="Variant.Text" Href="/admin/driver-registrations">Quay lại</MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Outlined" Disabled="@_reviewing" OnClick="@(()=>ReviewAsync(false))">Từ chối</MudButton>
            <MudButton Color="Color.Success" Variant="Variant.Filled" Disabled="@_reviewing" OnClick="@(()=>ReviewAsync(true))">Duyệt tài khoản</MudButton>
        </MudStack>
    </MudPaper>
}

<style>
.registration-signature { width:100%; max-height:220px; object-fit:contain; border:1px solid var(--mud-palette-lines-default); border-radius:8px; background:white; }
</style>

@code {
    [Parameter] public string UserId { get; set; } = string.Empty;
    private DriverRegistrationRequestDto? _item;
    private bool _loading = true;
    private bool _reviewing;
    private string? _reviewNote;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _item = await DriverAccountService.GetRegistrationDetailAsync(UserId);
        if (_item is not null)
        {
            var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var viewer = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
            await DriverAccountService.MarkRegistrationViewedAsync(UserId, viewer);
            _item.ViewedAt ??= DateTime.UtcNow;
            await RegistrationNotificationState.RefreshAsync();
        }
        _loading = false;
    }

    private async Task ReviewAsync(bool approve)
    {
        try
        {
            _reviewing = true;
            var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var reviewer = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
            await DriverAccountService.ReviewRegistrationAsync(UserId, approve, _reviewNote, reviewer);
            await RegistrationNotificationState.RefreshAsync();
            Snackbar.Add(approve ? "Đã duyệt và mở khóa tài khoản." : "Đã từ chối yêu cầu.", approve ? Severity.Success : Severity.Warning);
            Navigation.NavigateTo("/admin/driver-registrations");
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _reviewing = false; }
    }

    private static string FormatDate(DateTime? value) => value?.ToString("dd/MM/yyyy") ?? "—";
}
