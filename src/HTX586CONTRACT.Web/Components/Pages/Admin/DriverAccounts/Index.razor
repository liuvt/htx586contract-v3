@page "/admin/driver-accounts"
@attribute [Authorize(Roles = "Owner,Admin")]
@inject IDriverAccountService Service
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<ApplicationDbContext> Factory

<PageTitle>Tài xế</PageTitle>
<PageHeader Title="Tài xế" Subtitle="Quản lý thông tin và quyền hạn của các tài khoản tài xế trong hệ thống." />

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
    <MudText Typo="Typo.h4">Quản lý tài xế</MudText>

    <MudButton Color="Color.Primary"
               Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => Navigation.NavigateTo("/admin/driver-accounts/create"))">
        Tạo tài xế
    </MudButton>
</MudStack>

<MudPaper Class="pa-4 mt-4" Elevation="1">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
        <MudTextField T="string"
                      @bind-Value="_filter.Keyword"
                      Label="Tìm kiếm"
                      Placeholder="Tên, mã NV, số điện thoại, CCCD..."
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="false"
                      OnKeyDown="HandleSearchKeyDown" />

        <MudSelect T="bool?"
                   @bind-Value="_filter.IsActive"
                   Label="Trạng thái"
                   Variant="Variant.Outlined"
                   Clearable="true">
            <MudSelectItem T="bool?" Value="@((bool?)true)">Hoạt động</MudSelectItem>
            <MudSelectItem T="bool?" Value="@((bool?)false)">Đã khóa</MudSelectItem>
        </MudSelect>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="LoadAsync">
            Lọc
        </MudButton>
    </MudStack>
</MudPaper>

<MudTable T="DriverAccountDto"
          Items="_items"
          Loading="_loading"
          Hover="true"
          Striped="true"
          RowsPerPage="20"
          Class="mt-4"
          Breakpoint="Breakpoint.Sm">
    <HeaderContent>
        <MudTh>Mã nhân viên</MudTh>
        <MudTh>Họ tên</MudTh>
        <MudTh>Công ty</MudTh>
        <MudTh>CCCD</MudTh>
        <MudTh>GPLX</MudTh>
        <MudTh>Chữ ký</MudTh>
        <MudTh>Trạng thái</MudTh>
        <MudTh></MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd DataLabel="Mã nhân viên">@Display(context.EmployeeCode)</MudTd>
        <MudTd DataLabel="Họ tên">@Display(context.FullName)</MudTd>
        <MudTd DataLabel="Công ty">@Display(context.CompanyName)</MudTd>
        <MudTd DataLabel="CCCD">@Display(context.CitizenId)</MudTd>
        <MudTd DataLabel="GPLX">@DisplayLicense(context.DriverLicenseNumber, context.DriverLicenseClass)</MudTd>

        <MudTd DataLabel="Chữ ký">
            <MudChip T="string"
                     Size="Size.Small"
                     Color="@GetSignatureColor(context)">
                @GetSignatureText(context)
            </MudChip>
        </MudTd>

        <MudTd DataLabel="Trạng thái">
            <MudChip T="string"
                     Size="Size.Small"
                     Color="@(context.IsActive ? Color.Success : Color.Error)">
                @(context.IsActive ? "Hoạt động" : "Đã khóa")
            </MudChip>
        </MudTd>

        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                           Color="Color.Info"
                           OnClick="@(() => Navigation.NavigateTo($"/admin/driver-accounts/{context.Id}"))" />

            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Color="Color.Primary"
                           OnClick="@(() => Navigation.NavigateTo($"/admin/driver-accounts/{context.Id}/edit"))" />
        </MudTd>
    </RowTemplate>

    <NoRecordsContent>
        <MudText Class="pa-4">Không có tài xế phù hợp.</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="_pageSizeOptions" />
    </PagerContent>
</MudTable>

@code {
    private readonly DriverAccountFilter _filter = new()
    {
        Page = 1,
        PageSize = 0
    };

    private static readonly int[] _pageSizeOptions = [10, 20, 50, 100];
    private IReadOnlyList<DriverAccountDto> _items = Array.Empty<DriverAccountDto>();
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        if (!auth.User.IsInRole("Owner"))
        {
            var currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

            await using var db = await Factory.CreateDbContextAsync();

            _filter.CompanyProfileId = (await db.Users.AsNoTracking()
                .Where(x => x.Id == currentUserId)
                .Select(x => x.CompanyProfileId)
                .FirstOrDefaultAsync()) ?? Guid.Empty;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        try
        {
            _items = await Service.GetListAsync(_filter);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await LoadAsync();
        }
    }

    private static string Display(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string DisplayLicense(string? number, string? licenseClass)
    {
        if (string.IsNullOrWhiteSpace(number) && string.IsNullOrWhiteSpace(licenseClass))
        {
            return "—";
        }

        return string.IsNullOrWhiteSpace(licenseClass)
            ? number ?? "—"
            : $"{number} ({licenseClass})";
    }

    private static Color GetSignatureColor(DriverAccountDto item)
    {
        if (string.IsNullOrWhiteSpace(item.DriverSignatureFileUrl))
        {
            return Color.Warning;
        }

        return item.DriverSignatureIsActive ? Color.Success : Color.Default;
    }

    private static string GetSignatureText(DriverAccountDto item)
    {
        if (string.IsNullOrWhiteSpace(item.DriverSignatureFileUrl))
        {
            return "Thiếu";
        }

        return item.DriverSignatureIsActive ? "Đang dùng" : "Đã hủy";
    }
}
