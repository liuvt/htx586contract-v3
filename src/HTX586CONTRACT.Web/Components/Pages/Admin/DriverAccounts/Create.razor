@page "/admin/driver-accounts/create"
@attribute [Authorize(Roles = "Owner,Admin")]
@inject IDriverAccountService DriverAccountService
@inject ICompanyProfileService CompanyProfileService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDbContextFactory<ApplicationDbContext> Factory
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Thêm tài xế</PageTitle>
<PageHeader Title="Thêm tài xế" Subtitle="Tạo tài khoản đăng nhập, hồ sơ cá nhân, CCCD, GPLX và gán Company." />

<MudForm @ref="_form" @bind-IsValid="_valid">
    <MudPaper Class="pa-4" Elevation="1">
        <MudGrid>
            <MudItem xs="12">
                <MudSelect T="Guid"
                           @bind-Value="_model.CompanyProfileId"
                           Label="Công ty/Văn phòng đại diện"
                           Required="true"
                           Variant="Variant.Outlined"
                           Disabled="@(!_canChooseCompany)">
                    @foreach (var company in _companies)
                    {
                        <MudSelectItem T="Guid" Value="@company.Id">
                            @company.CompanyName (@company.TaxCode)
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.UserName" Label="Tên đăng nhập" Required="true" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.Password" Label="Mật khẩu ban đầu" Required="true" InputType="InputType.Password" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.FullName" Label="Họ và tên" Required="true" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.EmployeeCode" Label="Mã nhân viên" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.PhoneNumber" Label="Số điện thoại" Required="true" HelperText="@VietnamPhoneNumber.ValidationMessage" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.CitizenId" Label="Số CCCD" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudDatePicker @bind-Date="_model.CitizenIdIssuedDate" Label="Ngày cấp CCCD" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.CitizenIdIssuedPlace" Label="Nơi cấp CCCD" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudDatePicker @bind-Date="_model.DateOfBirth" Label="Ngày sinh" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.AreaCode" Label="Khu vực" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.Address" Label="Địa chỉ" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.DriverLicenseNumber" Label="Số GPLX" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_model.DriverLicenseClass" Label="Hạng GPLX" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudDatePicker @bind-Date="_model.DriverLicenseIssuedDate" Label="Ngày cấp GPLX" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudDatePicker @bind-Date="_model.DriverLicenseExpiryDate" Label="Hết hạn GPLX" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12">
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Tài khoản do Owner/Admin cấp sẽ bắt buộc tài xế đổi mật khẩu và tạo chữ ký cố định
                    ở lần đăng nhập đầu tiên. Quản trị viên không nhập chữ ký thay tài xế tại bước này.
                </MudAlert>
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Class="mt-4">
            <MudButton Variant="Variant.Outlined" OnClick="@(() => Navigation.NavigateTo("/admin/driver-accounts"))">
                Hủy
            </MudButton>

            <MudSpacer />

            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       Disabled="_saving"
                       OnClick="SaveAsync">
                Tạo tài xế
            </MudButton>
        </MudStack>
    </MudPaper>
</MudForm>

@code {
    private MudForm? _form;
    private bool _valid;
    private bool _saving;
    private CreateDriverAccountRequest _model = new() { MustChangePassword = true };
    private IReadOnlyList<CompanyProfileOptionDto> _companies = [];
    private bool _canChooseCompany;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        _canChooseCompany = auth.User.IsInRole("Owner");

        var allCompanies = await CompanyProfileService.GetActiveOptionsAsync();

        if (_canChooseCompany)
        {
            _companies = allCompanies;
        }
        else
        {
            var currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

            await using var db = await Factory.CreateDbContextAsync();

            var allowedCompanyId = await db.Users.AsNoTracking()
                .Where(x => x.Id == currentUserId)
                .Select(x => x.CompanyProfileId)
                .FirstOrDefaultAsync();

            _companies = allowedCompanyId.HasValue
                ? allCompanies.Where(x => x.Id == allowedCompanyId.Value).ToList()
                : [];
        }

        _model.CompanyProfileId = _companies.FirstOrDefault()?.Id ?? Guid.Empty;
    }

    private async Task SaveAsync()
    {
        await _form!.ValidateAsync();

        if (!_valid)
        {
            return;
        }

        _saving = true;

        try
        {
            _model.MustChangePassword = true;
            var id = await DriverAccountService.CreateAsync(_model);

            Snackbar.Add("Đã tạo tài khoản tài xế. Lần đăng nhập đầu tiên tài xế phải đổi mật khẩu và tạo chữ ký cố định.", Severity.Success);
            Navigation.NavigateTo($"/admin/driver-accounts/{id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
