@page "/admin/customers"
@attribute [Authorize(Roles = "Owner,Admin")]
@inject IDbContextFactory<ApplicationDbContext> Factory
@inject ISnackbar Snackbar

<PageTitle>Quản lý khách hàng</PageTitle>
<PageHeader Title="Quản lý khách hàng" Subtitle="Khách hàng có thể là cá nhân hoặc đơn vị; mỗi bản ghi lưu tài xế đã tạo để phục vụ tra cứu cá nhân." />

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid>
        <MudItem xs="12" md="8"><MudTextField T="string" @bind-Value="_keyword" Placeholder="Tìm tên, số điện thoại, CCCD, mã số thuế..." Immediate="true" Clearable="true" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="4" Class="d-flex align-center justify-end"><MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="NewCustomer">Thêm khách hàng</MudButton></MudItem>
    </MudGrid>
</MudPaper>

@if (_editing)
{
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudGrid>
            <MudItem xs="12" md="3"><MudSelect T="CustomerType" @bind-Value="_model.Type" Label="Loại khách hàng" Variant="Variant.Outlined"><MudSelectItem Value="@CustomerType.Individual">Cá nhân</MudSelectItem><MudSelectItem Value="@CustomerType.Organization">Đơn vị/Tổ chức</MudSelectItem></MudSelect></MudItem>
            <MudItem xs="12" md="3"><MudSelect T="string" @bind-Value="_model.CreatedByDriverId" Label="Tài xế quản lý" Required="true" Variant="Variant.Outlined">@foreach(var driver in _drivers){<MudSelectItem T="string" Value="@driver.Id">@driver.FullName</MudSelectItem>}</MudSelect></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="_model.FullName" Label="Họ tên người liên hệ" Required="true" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="_model.PhoneNumber" Label="Số điện thoại" Required="true" Variant="Variant.Outlined" /></MudItem>
            @if (_model.Type == CustomerType.Organization)
            {
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_model.OrganizationName" Label="Tên đơn vị/Tổ chức" Required="true" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12" md="3"><MudTextField @bind-Value="_model.TaxCode" Label="Mã số thuế" Variant="Variant.Outlined" /></MudItem>
            }
            <MudItem xs="12" md="3"><MudTextField @bind-Value="_model.CitizenId" Label="CCCD" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="3"><MudDatePicker @bind-Date="_model.DateOfBirth" Label="Ngày sinh" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_model.Address" Label="Địa chỉ" Variant="Variant.Outlined" /></MudItem>
        </MudGrid>
        <MudStack Row="true" Class="mt-4"><MudButton Variant="Variant.Outlined" OnClick="CancelEdit">Hủy</MudButton><MudSpacer /><MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_saving" OnClick="SaveAsync">Lưu khách hàng</MudButton></MudStack>
    </MudPaper>
}

<MudTable T="CustomerRow" Items="FilteredItems" Loading="_loading" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
    <HeaderContent><MudTh>Khách hàng</MudTh><MudTh>Loại</MudTh><MudTh>Điện thoại</MudTh><MudTh>CCCD/MST</MudTh><MudTh>Tài xế quản lý</MudTh><MudTh>Số HĐ</MudTh><MudTh></MudTh></HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Khách hàng"><b>@context.DisplayName</b><br /><small>@context.Address</small></MudTd>
        <MudTd DataLabel="Loại">@(context.Type == CustomerType.Organization ? "Đơn vị" : "Cá nhân")</MudTd>
        <MudTd DataLabel="Điện thoại">@context.PhoneNumber</MudTd>
        <MudTd DataLabel="CCCD/MST">@(context.Type == CustomerType.Organization ? context.TaxCode : context.CitizenId)</MudTd>
        <MudTd DataLabel="Tài xế">@context.DriverName</MudTd>
        <MudTd DataLabel="Số HĐ">@context.ContractCount</MudTd>
        <MudTd><MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="@(() => EditAsync(context.Id))" /></MudTd>
    </RowTemplate>
    <NoRecordsContent><MudText Class="pa-4">Chưa có khách hàng.</MudText></NoRecordsContent>
</MudTable>

@code {
    private bool _loading;
    private bool _saving;
    private bool _editing;
    private string? _keyword;
    private List<CustomerRow> _items = [];
    private List<ApplicationUser> _drivers = [];
    private Customer _model = NewModel();

    private IEnumerable<CustomerRow> FilteredItems => string.IsNullOrWhiteSpace(_keyword) ? _items : _items.Where(x =>
        Contains(x.DisplayName) || Contains(x.PhoneNumber) || Contains(x.CitizenId) || Contains(x.TaxCode) || Contains(x.DriverName));

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            await using var db = await Factory.CreateDbContextAsync();
            _drivers = await (from u in db.Users
                              join ur in db.UserRoles on u.Id equals ur.UserId
                              join r in db.Roles on ur.RoleId equals r.Id
                              where r.Name == "Driver"
                              orderby u.FullName
                              select u).AsNoTracking().ToListAsync();
            _items = await db.Customers.AsNoTracking().OrderByDescending(x => x.LastUsedAt ?? x.CreatedAt)
                .Select(x => new CustomerRow
                {
                    Id = x.Id,
                    Type = x.Type,
                    DisplayName = x.Type == CustomerType.Organization && x.OrganizationName != null ? x.OrganizationName : x.FullName,
                    PhoneNumber = x.PhoneNumber,
                    CitizenId = x.CitizenId,
                    TaxCode = x.TaxCode,
                    Address = x.Address,
                    DriverName = x.CreatedByDriver.FullName,
                    ContractCount = x.Contracts.Count
                }).ToListAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _loading = false; }
    }

    private void NewCustomer()
    {
        _model = NewModel();
        _model.CreatedByDriverId = _drivers.FirstOrDefault()?.Id ?? string.Empty;
        _editing = true;
    }

    private async Task EditAsync(Guid id)
    {
        await using var db = await Factory.CreateDbContextAsync();
        var entity = await db.Customers.AsNoTracking().FirstOrDefaultAsync(x => x.Id == id);
        if (entity is null) return;
        _model = entity;
        _editing = true;
    }

    private void CancelEdit() { _editing = false; _model = NewModel(); }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_model.FullName) || string.IsNullOrWhiteSpace(_model.PhoneNumber) || string.IsNullOrWhiteSpace(_model.CreatedByDriverId))
        {
            Snackbar.Add("Vui lòng nhập họ tên, số điện thoại và tài xế quản lý.", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            await using var db = await Factory.CreateDbContextAsync();
            var entity = await db.Customers.FirstOrDefaultAsync(x => x.Id == _model.Id);
            if (entity is null)
            {
                entity = new Customer { Id = Guid.NewGuid(), CreatedAt = DateTime.UtcNow };
                db.Customers.Add(entity);
            }
            Map(entity, _model);
            entity.UpdatedAt = DateTime.UtcNow;
            await db.SaveChangesAsync();
            Snackbar.Add("Đã lưu khách hàng.", Severity.Success);
            _editing = false;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _saving = false; }
    }

    private bool Contains(string? value) => !string.IsNullOrWhiteSpace(value) && value.Contains(_keyword!.Trim(), StringComparison.OrdinalIgnoreCase);
    private static Customer NewModel() => new() { Type = CustomerType.Individual };
    private static void Map(Customer target, Customer source)
    {
        target.Type = source.Type;
        target.FullName = source.FullName.Trim();
        target.OrganizationName = N(source.OrganizationName);
        target.TaxCode = N(source.TaxCode);
        target.PhoneNumber = source.PhoneNumber.Trim();
        target.CitizenId = N(source.CitizenId);
        target.DateOfBirth = source.DateOfBirth;
        target.Address = N(source.Address);
        target.Email = N(source.Email);
        target.CreatedByDriverId = source.CreatedByDriverId;
    }
    private static string? N(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class CustomerRow
    {
        public Guid Id { get; set; }
        public CustomerType Type { get; set; }
        public string DisplayName { get; set; } = string.Empty;
        public string PhoneNumber { get; set; } = string.Empty;
        public string? CitizenId { get; set; }
        public string? TaxCode { get; set; }
        public string? Address { get; set; }
        public string DriverName { get; set; } = string.Empty;
        public int ContractCount { get; set; }
    }
}
