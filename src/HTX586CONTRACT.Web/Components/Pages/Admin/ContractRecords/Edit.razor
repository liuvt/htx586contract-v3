        => SelectedDriver?.DriverSignedAt;

    private ContractSignatureDto? GetSignature(SignatureParty party)
        => _signatures.FirstOrDefault(x => x.Party == party);

    private string? SignatureUrl(SignatureParty party)
        => GetSignature(party)?.SignatureFileUrl;

    private string? SignatureName(SignatureParty party)
        => GetSignature(party)?.SignerName;

    private DateTime? SignatureTime(SignatureParty party)
        => GetSignature(party)?.ServerSignedAt;

    private async Task GeneratePdfAsync()
    {
        if (!Id.HasValue)
            return;

        try
        {
            var url = await DocumentService.GeneratePdfAsync(Id.Value);
            Navigation.NavigateTo(url, true);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
