        => SelectedCompany?.RepresentativeSignedAt;

    private string? FixedOwnerSignatureUrl
        => SelectedVehicle?.OwnerSignatureFileUrl;

    private DateTime? FixedOwnerSignedAt
        => SelectedVehicle?.OwnerSignedAt;

    private string? FixedDriverSignatureUrl
        => SelectedDriver?.DriverSignatureFileUrl;

