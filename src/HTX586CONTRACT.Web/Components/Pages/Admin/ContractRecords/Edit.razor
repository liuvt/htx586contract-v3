    private string OwnerSigner
        => SelectedVehicle?.OwnerName ?? "Chủ sở hữu xe";

    private string DriverSigner
        => SelectedDriver?.FullName ?? "Tài xế";

    private string? FixedOfficeSignatureUrl
        => SelectedCompany?.RepresentativeSignatureFileUrl;

