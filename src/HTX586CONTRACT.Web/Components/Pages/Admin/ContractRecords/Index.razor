@namespace HTX586CONTRACT.Web.Components.Pages.Admin.ContractRecords
@page "/admin/contracts"
@attribute [Authorize(Roles = "Admin")]
@inject IContractService ContractService
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<ApplicationDbContext> Factory

<PageTitle>Hợp đồng</PageTitle>
<PageHeader Title="Hợp đồng" Subtitle="Admin quản lý hợp đồng thuộc Công ty/Văn phòng được phân quyền." />

@if (!_currentCompanyProfileId.HasValue && !_loading)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
        Tài khoản Admin chưa được gán Công ty/Văn phòng nên chưa thể quản lý hợp đồng.
    </MudAlert>
}

<MudPaper Class="pa-4" Outlined="true">
    <MudStack Row="true" Spacing="2" Class="mb-4">
        <MudTextField @bind-Value="_search"
                      Label="Tìm số hợp đồng, khách hàng, biển số"
                      Variant="Variant.Outlined"
                      Immediate="true"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" />
        <MudSelect T="ContractStatus?" @bind-Value="_status" Label="Trạng thái" Variant="Variant.Outlined" Clearable="true">
            @foreach (var status in Enum.GetValues<ContractStatus>())
            {
                <MudSelectItem T="ContractStatus?" Value="@status">@StatusText(status)</MudSelectItem>
            }
        </MudSelect>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="LoadAsync">Lọc</MudButton>
        <MudSpacer />
        <MudButton Color="Color.Success"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/admin/contracts/create"
                   Disabled="@(!_currentCompanyProfileId.HasValue)">
            Tạo hợp đồng
        </MudButton>
    </MudStack>

    <MudTable Items="_items" Hover="true" Dense="true" Loading="_loading" RowsPerPage="20">
        <HeaderContent>
            <MudTh>Số hợp đồng</MudTh>
            <MudTh>Khách hàng</MudTh>
            <MudTh>Tài xế</MudTh>
            <MudTh>Biển số</MudTh>
            <MudTh>Khởi hành</MudTh>
            <MudTh>Giá trị</MudTh>
            <MudTh>Trạng thái</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Số hợp đồng">
                <MudLink Href="@($"/admin/contracts/{context.Id}")">@context.ContractNumber</MudLink>
            </MudTd>
            <MudTd DataLabel="Khách hàng">@context.CustomerName</MudTd>
            <MudTd DataLabel="Tài xế">@context.DriverName</MudTd>
            <MudTd DataLabel="Biển số">@context.VehiclePlate</MudTd>
            <MudTd DataLabel="Khởi hành">@context.StartTime?.ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd DataLabel="Giá trị">@context.ContractValue?.ToString("N0")</MudTd>
            <MudTd DataLabel="Trạng thái"><ContractStatusChip Status="context.Status" /></MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Href="@($"/admin/contracts/{context.Id}")" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteAsync(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent><MudText>Chưa có hợp đồng.</MudText></NoRecordsContent>
        <PagerContent><MudTablePager PageSizeOptions="_pageSizeOptions" /></PagerContent>
    </MudTable>
</MudPaper>

@code {
    private static readonly int[] _pageSizeOptions = [10, 20, 50, 100];
    private List<ContractListItemDto> _items = [];
    private string? _search;
    private ContractStatus? _status;
    private bool _loading = true;
    private string _currentUserId = string.Empty;
    private Guid? _currentCompanyProfileId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

        await using var db = await Factory.CreateDbContextAsync();
        _currentCompanyProfileId = await db.Users.AsNoTracking()
            .Where(x => x.Id == _currentUserId)
            .Select(x => x.CompanyProfileId)
            .FirstOrDefaultAsync();

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            if (!_currentCompanyProfileId.HasValue)
            {
                _items = [];
                return;
            }

            _items = (await ContractService.GetAsync(new ContractFilter
            {
                Search = _search,
                Status = _status,
                CompanyProfileId = _currentCompanyProfileId
            })).ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DeleteAsync(ContractListItemDto item)
    {
        var confirmed = await Dialog.ShowMessageBoxAsync(
            "Xóa hợp đồng",
            $"Xóa hợp đồng {item.ContractNumber}?",
            yesText: "Xóa",
            cancelText: "Hủy");

        if (confirmed != true)
            return;

        await ContractService.DeleteAsync(item.Id, _currentUserId);
        Snackbar.Add("Đã xóa hợp đồng.", Severity.Success);
        await LoadAsync();
    }

    private static string StatusText(ContractStatus status) => status switch
    {
        ContractStatus.Draft => "Phát xuống cho tài xế",
        ContractStatus.WaitingCustomerSignature => "Chờ khách ký",
        ContractStatus.CustomerSigned => "Khách đã ký",
        ContractStatus.WaitingDriverConfirmation => "Chờ tài xế",
        ContractStatus.Completed => "Hoàn tất",
        ContractStatus.Cancelled => "Đã hủy",
        ContractStatus.Expired => "Hết hạn",
        _ => "Vô hiệu"
    };
}
