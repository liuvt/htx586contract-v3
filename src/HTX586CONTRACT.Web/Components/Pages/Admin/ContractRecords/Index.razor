@page "/admin/contracts"
@attribute [Authorize(Roles="Owner,Admin")]
@inject IContractService ContractService
@inject NavigationManager Nav
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<ApplicationDbContext> Factory
<PageTitle>Quản lý hợp đồng</PageTitle>
<PageHeader Title="Quản lý hợp đồng" Subtitle="Admin tạo hợp đồng cơ bản và phát xuống tài xế; tài xế bổ sung thông tin khách hàng và chữ ký khách hàng." />
<MudPaper Class="pa-4" Outlined="true">
    <MudStack Row="true" Spacing="2" Class="mb-4">
        <MudTextField @bind-Value="_search" Label="Tìm số hợp đồng, khách hàng, biển số" Variant="Variant.Outlined" Immediate="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
        <MudSelect T="ContractStatus?" @bind-Value="_status" Label="Trạng thái" Variant="Variant.Outlined" Clearable="true">
            @foreach (var s in Enum.GetValues<ContractStatus>()) { <MudSelectItem T="ContractStatus?" Value="@s">@StatusText(s)</MudSelectItem> }
        </MudSelect>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="LoadAsync">Lọc</MudButton>
        <MudSpacer />
        <MudButton Color="Color.Success" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Href="/admin/contracts/create">Tạo hợp đồng cơ bản</MudButton>
    </MudStack>
    <MudTable Items="_items" Hover="true" Dense="true" Loading="_loading">
        <HeaderContent><MudTh>Số hợp đồng</MudTh><MudTh>Khách hàng</MudTh><MudTh>Tài xế</MudTh><MudTh>Biển số</MudTh><MudTh>Khởi hành</MudTh><MudTh>Giá trị</MudTh><MudTh>Trạng thái</MudTh><MudTh></MudTh></HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Số hợp đồng"><MudLink Href="@($"/admin/contracts/{context.Id}")">@context.ContractNumber</MudLink></MudTd>
            <MudTd DataLabel="Khách hàng">@context.CustomerName</MudTd><MudTd DataLabel="Tài xế">@context.DriverName</MudTd><MudTd DataLabel="Biển số">@context.VehiclePlate</MudTd>
            <MudTd DataLabel="Khởi hành">@context.StartTime?.ToString("dd/MM/yyyy HH:mm")</MudTd><MudTd DataLabel="Giá trị">@context.ContractValue?.ToString("N0")</MudTd><MudTd><MudChip T="string" Size="Size.Small">@StatusText(context.Status)</MudChip></MudTd>
            <MudTd><MudIconButton Icon="@Icons.Material.Filled.Edit" Href="@($"/admin/contracts/{context.Id}")"/><MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(()=>DeleteAsync(context))"/></MudTd>
        </RowTemplate>
        <NoRecordsContent><MudText>Chưa có hợp đồng.</MudText></NoRecordsContent>
    </MudTable>
</MudPaper>
@code {
    private List<ContractListItemDto> _items=[]; private string? _search; private ContractStatus? _status; private bool _loading;
    private string _currentUserId = string.Empty; private bool _isOwner; private Guid? _currentCompanyProfileId;
    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
        _isOwner = auth.User.IsInRole("Owner");
        await using var db = await Factory.CreateDbContextAsync();
        _currentCompanyProfileId = await db.Users.AsNoTracking().Where(x => x.Id == _currentUserId).Select(x => x.CompanyProfileId).FirstOrDefaultAsync();
        await LoadAsync();
    }
    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            if (!_isOwner && !_currentCompanyProfileId.HasValue)
            {
                _items = [];
                return;
            }

            _items = (await ContractService.GetAsync(new()
            {
                Search = _search,
                Status = _status,
                CompanyProfileId = _isOwner ? null : _currentCompanyProfileId
            })).ToList();
        }
        finally { _loading = false; }
    }
    private async Task DeleteAsync(ContractListItemDto item) { var ok = await Dialog.ShowMessageBoxAsync("Xóa hợp đồng", $"Xóa hợp đồng {item.ContractNumber}?", yesText: "Xóa", cancelText: "Hủy"); if (ok == true) { await ContractService.DeleteAsync(item.Id, _currentUserId); Snackbar.Add("Đã xóa hợp đồng.", Severity.Success); await LoadAsync(); } }
    private static string StatusText(ContractStatus s)=>s switch{ContractStatus.Draft=>"Nháp/đã phát xuống tài xế",ContractStatus.WaitingCustomerSignature=>"Chờ khách ký",ContractStatus.CustomerSigned=>"Khách đã ký",ContractStatus.WaitingDriverConfirmation=>"Chờ tài xế",ContractStatus.Completed=>"Hoàn tất",ContractStatus.Cancelled=>"Đã hủy",ContractStatus.Expired=>"Hết hạn",_=>"Vô hiệu"};
}
