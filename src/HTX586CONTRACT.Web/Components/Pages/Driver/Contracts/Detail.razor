@page "/driver/contracts/detail/{Id:guid}"
@attribute [Authorize(Roles = "Driver")]
@inject IContractService ContractService
@inject IContractDocumentService DocumentService
@inject IDbContextFactory<ApplicationDbContext> Factory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Chi tiết hợp đồng</PageTitle>
<PageHeader Title="Chi tiết hợp đồng"
            Subtitle="Xem lại thông tin và lịch sử hợp đồng đã được giao hoặc đã hoàn thành.">
    <MudButton Href="/driver/contracts"
               Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.ArrowBack">
        Quay lại
    </MudButton>
</PageHeader>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_detail is null)
{
    <MudAlert Severity="Severity.Error">Không tìm thấy hợp đồng hoặc bạn không có quyền xem.</MudAlert>
}
else
{
    <MudStack Spacing="3">
        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <div>
                    <MudText Typo="Typo.h5">@_detail.ContractNumber</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_detail.CompanyName · @BusinessName(_detail.BusinessType)
                    </MudText>
                </div>
                <MudSpacer />
                <ContractStatusChip Status="_detail.Status" ChipSize="Size.Medium" />
            </MudStack>
        </MudPaper>

        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            <b>Người tạo:</b> @_detail.CreatedByName
            lúc @VietnamTime(_detail.CreatedAt).ToString("dd/MM/yyyy HH:mm").
            @if (!string.IsNullOrWhiteSpace(_detail.AssignedByName))
            {
                <span>
                    <b> Người phát xuống:</b> @_detail.AssignedByName
                    @if (_detail.AssignedAt.HasValue)
                    {
                        <span> lúc @VietnamTime(_detail.AssignedAt.Value).ToString("dd/MM/yyyy HH:mm")</span>
                    }.
                </span>
            }
            else
            {
                <span> Hợp đồng do tài xế tự tạo.</span>
            }
        </MudAlert>

        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-3">1. Thông tin hợp đồng</MudText>
            <MudGrid>
                <MudItem xs="12" md="4"><InfoListItem Label="Số hợp đồng" Value="@_detail.ContractNumber" /></MudItem>
                <MudItem xs="12" md="4"><InfoListItem Label="Loại hợp đồng" Value="@BusinessName(_detail.BusinessType)" /></MudItem>
                <MudItem xs="12" md="4"><InfoListItem Label="Trạng thái" Value="@StatusName(_detail.Status)" /></MudItem>
                <MudItem xs="12" md="4"><InfoListItem Label="Công ty/Văn phòng" Value="@_detail.CompanyName" /></MudItem>
                <MudItem xs="12" md="4"><InfoListItem Label="Tài xế" Value="@_detail.DriverName" /></MudItem>
                <MudItem xs="12" md="4"><InfoListItem Label="Khu vực" Value="@_detail.AreaCode" /></MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-3">2. Phương tiện</MudText>
            <MudGrid>
                <MudItem xs="12" md="4"><InfoListItem Label="Biển kiểm soát" Value="@(_detail.VehiclePlate ?? "-")" /></MudItem>
                <MudItem xs="12" md="4"><InfoListItem Label="Hãng/Loại xe" Value="@(_detail.VehicleBrand ?? "-")" /></MudItem>
                <MudItem xs="12" md="4"><InfoListItem Label="Số chỗ" Value="@FormatNumber(_detail.SeatCount)" /></MudItem>
                <MudItem xs="12" md="6"><InfoListItem Label="Chủ sở hữu" Value="@(_detail.OwnerName ?? "-")" /></MudItem>
                <MudItem xs="12" md="6"><InfoListItem Label="CCCD chủ sở hữu" Value="@(_detail.OwnerCitizenId ?? "-")" /></MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-3">3. Khách hàng/người thuê</MudText>
            <MudGrid>
                <MudItem xs="12" md="4"><InfoListItem Label="Khách hàng/người thuê" Value="@_detail.CustomerName" /></MudItem>
                <MudItem xs="12" md="4"><InfoListItem Label="Số điện thoại" Value="@_detail.CustomerPhone" /></MudItem>
                <MudItem xs="12" md="4"><InfoListItem Label="CCCD/MST" Value="@(_detail.CustomerCitizenId ?? "-")" /></MudItem>
                <MudItem xs="12"><InfoListItem Label="Địa chỉ" Value="@(_detail.CustomerAddress ?? "-")" /></MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-3">4. Nội dung hợp đồng</MudText>
            <MudGrid>
                <MudItem xs="12" md="3"><InfoListItem Label="Bắt đầu" Value="@FormatDateTime(_detail.StartTime)" /></MudItem>
                <MudItem xs="12" md="3"><InfoListItem Label="Kết thúc" Value="@FormatDateTime(_detail.EndTime)" /></MudItem>
                <MudItem xs="12" md="3"><InfoListItem Label="Tổng km" Value="@FormatDecimal(_detail.TotalKilometers)" /></MudItem>
                <MudItem xs="12" md="3"><InfoListItem Label="Giá trị hợp đồng" Value="@FormatMoney(_detail.ContractValue)" /></MudItem>
                <MudItem xs="12" md="6"><InfoListItem Label="Điểm đi" Value="@(_detail.PickupLocation ?? "-")" /></MudItem>
                <MudItem xs="12" md="6"><InfoListItem Label="Điểm đến" Value="@(_detail.DropoffLocation ?? "-")" /></MudItem>
                <MudItem xs="12"><InfoListItem Label="Lộ trình chi tiết" Value="@(_detail.RouteDescription ?? "-")" /></MudItem>
                <MudItem xs="12" md="6"><InfoListItem Label="Hình thức thanh toán" Value="@(_detail.PaymentMethod ?? "-")" /></MudItem>
                <MudItem xs="12" md="6"><InfoListItem Label="Thời gian thanh toán" Value="@(_detail.PaymentTime ?? "-")" /></MudItem>
                <MudItem xs="12"><InfoListItem Label="Ghi chú" Value="@(_detail.Note ?? "-")" /></MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">5. Danh sách hành khách</MudText>
                <MudSpacer />
                <MudChip T="string" Variant="Variant.Outlined">Số lượng: @FormatNumber(_detail.ActualPassengerCount)</MudChip>
            </MudStack>
            <MudTable T="ContractPassengerDto" Items="_detail.Passengers" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>STT</MudTh>
                    <MudTh>Họ tên</MudTh>
                    <MudTh>Năm sinh</MudTh>
                    <MudTh>Ghi chú</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="STT">@context.SortOrder</MudTd>
                    <MudTd DataLabel="Họ tên">@context.FullName</MudTd>
                    <MudTd DataLabel="Năm sinh">@context.BirthYear</MudTd>
                    <MudTd DataLabel="Ghi chú">@context.Note</MudTd>
                </RowTemplate>
                <NoRecordsContent><MudText>Không có hành khách bổ sung.</MudText></NoRecordsContent>
            </MudTable>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-3">Lịch sử chữ ký</MudText>
            <MudTable T="ContractSignatureDto" Items="_detail.Signatures" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Bên ký</MudTh>
                    <MudTh>Người ký</MudTh>
                    <MudTh>Thời gian</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Bên ký">@SignaturePartyName(context.Party)</MudTd>
                    <MudTd DataLabel="Người ký">@context.SignerName</MudTd>
                    <MudTd DataLabel="Thời gian">@VietnamTime(context.ServerSignedAt).ToString("dd/MM/yyyy HH:mm:ss")</MudTd>
                </RowTemplate>
                <NoRecordsContent><MudText>Chưa có chữ ký.</MudText></NoRecordsContent>
            </MudTable>
        </MudPaper>

        <MudStack Row="true" Justify="Justify.FlexEnd">
            @if (!IsHistoryStatus(_detail.Status) && _canEditCurrentContract)
            {
                <MudButton Href="@($"/driver/contracts/{Id}")"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.Edit">
                    Tiếp tục xử lý
                </MudButton>
            }
            @if (_detail.Status == ContractStatus.Completed)
            {
                <MudButton Color="Color.Success"
                           Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.PictureAsPdf"
                           OnClick="OpenPdfAsync">
                    Mở PDF
                </MudButton>
            }
        </MudStack>
    </MudStack>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private bool _canEditCurrentContract;
    private string _userId = string.Empty;
    private ContractDetailDto? _detail;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        try
        {
            var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            _userId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

            var detail = await ContractService.GetByIdAsync(Id);
            if (detail is null || detail.DriverId != _userId)
            {
                _detail = null;
                return;
            }

            await using var db = await Factory.CreateDbContextAsync();
            _canEditCurrentContract = detail.VehicleId.HasValue &&
                await db.Vehicles.AsNoTracking().AnyAsync(x =>
                    x.Id == detail.VehicleId.Value &&
                    x.IsActive &&
                    x.AssignedDriverId == _userId);

            // Hợp đồng đang xử lý chỉ được xem khi xe hiện còn gán cho tài xế.
            // Hợp đồng đã kết thúc luôn được phép xem lại như lịch sử.
            if (!IsHistoryStatus(detail.Status) && !_canEditCurrentContract)
            {
                Snackbar.Add("Hợp đồng đang xử lý chỉ hiển thị khi xe của hợp đồng còn được gán cho tài xế.", Severity.Warning);
                _detail = null;
                return;
            }

            _detail = detail;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _detail = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenPdfAsync()
    {
        try
        {
            var url = await DocumentService.GeneratePdfAsync(Id);
            Navigation.NavigateTo(url, true);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private static bool IsHistoryStatus(ContractStatus status)
        => status is ContractStatus.Completed
            or ContractStatus.Cancelled
            or ContractStatus.Expired
            or ContractStatus.Invalidated;

    private static DateTime VietnamTime(DateTime value)
        => value.Kind == DateTimeKind.Utc ? value.AddHours(7) : value;

    private static string FormatDateTime(DateTime? value)
        => value.HasValue ? VietnamTime(value.Value).ToString("dd/MM/yyyy HH:mm") : "-";

    private static string FormatMoney(decimal? value)
        => value.HasValue ? $"{value.Value:N0} VNĐ" : "-";

    private static string FormatDecimal(decimal? value)
        => value.HasValue ? value.Value.ToString("N0") : "-";

    private static string FormatNumber(int? value)
        => value.HasValue ? value.Value.ToString("N0") : "-";

    private static string BusinessName(ContractBusinessType type) => type switch
    {
        ContractBusinessType.Passenger => "HỢP ĐỒNG VẬN CHUYỂN HÀNH KHÁCH",
        ContractBusinessType.Cargo => "HỢP ĐỒNG VẬN CHUYỂN HÀNG HÓA BẰNG XE Ô TÔ",
        _ => "Loại hợp đồng cũ"
    };

    private static string SignaturePartyName(SignatureParty party) => party switch
    {
        SignatureParty.RepresentativeOffice => "Công ty/Văn phòng",
        SignatureParty.VehicleOwner => "Chủ sở hữu xe",
        SignatureParty.Driver => "Tài xế",
        SignatureParty.Customer => "Khách hàng",
        _ => party.ToString()
    };


    private static string StatusName(ContractStatus status) => status switch
    {
        ContractStatus.Completed => "Hoàn tất",
        ContractStatus.Cancelled => "Đã hủy",
        ContractStatus.Expired => "Hết hạn",
        ContractStatus.Invalidated => "Vô hiệu",
        ContractStatus.Draft => "Phát xuống cho tài xế",
        ContractStatus.WaitingCustomerSignature => "Chờ khách ký",
        ContractStatus.CustomerSigned => "Khách đã ký",
        ContractStatus.WaitingDriverConfirmation => "Chờ tài xế xác nhận",
        _ => "Đang xử lý"
    };
}
